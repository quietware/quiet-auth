<?xml version="1.0" encoding="utf-8"?>
<!--
  Disable cloud and device-to-device transfer of QuietAuth's encrypted token store. The
  AES-GCM key sits inside the AndroidKeyStore and is intentionally non-exportable; copying
  the SharedPreferences blob alone would never be useful, but we make the intent explicit.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="quietauth_secure_prefs_v1.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="quietauth_secure_prefs_v1.xml" />
    </device-transfer>
</data-extraction-rules>
